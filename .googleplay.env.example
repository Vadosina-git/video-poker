# Google Play Console upload credentials. Copy to .googleplay.env (gitignored)
# and fill. See docs/ANDROID_UPLOAD.md §4 for setup.
#
# GOOGLE_PLAY_JSON_KEY_PATH — service account JSON key downloaded from Google
#   Cloud Console (NOT committed). Conventionally lives in ~/.googleplay/.
# GOOGLE_PLAY_PACKAGE_NAME  — Android bundle ID, must match
#   export_presets.cfg → package/unique_name.
# GOOGLE_PLAY_TRACK         — internal | alpha | beta | production.
#   Default: internal (closed test, fastest review).
GOOGLE_PLAY_JSON_KEY_PATH="$HOME/.googleplay/play_upload_key.json"
GOOGLE_PLAY_PACKAGE_NAME="com.khralz.videopoker"
GOOGLE_PLAY_TRACK="internal"
