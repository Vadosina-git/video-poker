# App Store Connect API credentials.
# Copy this file to `.appstore.env` (gitignored) and fill in the real values.
# .p8 private keys live outside the repo — by convention in
#   ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
# Used by scripts/upload_testflight.sh.

# Account-level (same for every app on Team KQBUD75V9A)
APP_STORE_ISSUER_ID=
APP_STORE_API_KEY_ID=
APP_STORE_API_KEY_PATH=

# In-App Purchase key (optional — separate key for IAP StoreKit operations)
APP_STORE_IAP_KEY_ID=
APP_STORE_IAP_KEY_PATH=

# Per-app — filled after creating the App Store Connect record
APP_STORE_APP_APPLE_ID=
APP_STORE_BUNDLE_ID=com.khralz.videopoker

# Sandbox IAP tester credentials (shared across the team)
APP_STORE_SANDBOX_EMAIL=
APP_STORE_SANDBOX_PASSWORD=
