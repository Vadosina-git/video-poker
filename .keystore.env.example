# Android keystore credentials. Copy to .keystore.env (gitignored) and fill.
# scripts/build_android_release.sh sources this file at build time, injects
# values into export_presets.cfg, and reverts the file after export so secrets
# never land in git.
ANDROID_KEYSTORE_PATH="/Users/<you>/Documents/Godot/video poker/keystore/upload-keystore.jks"
ANDROID_KEYSTORE_USER="upload"
ANDROID_KEYSTORE_PASSWORD="<set-during-keystore-gen>"
